# LLM Provider: claude | azure_openai | ollama
LLM_PROVIDER=claude

# Claude (cloud demo)
ANTHROPIC_API_KEY=

# Azure OpenAI (enterprise)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Ollama (air-gapped)
OLLAMA_URL=http://localhost:11434

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Security
# Shared API key required in X-API-Key header. Leave empty to disable auth (dev only).
API_KEY=
# HMAC secret for signing session IDs. Use `openssl rand -hex 32` to generate.
SESSION_SIGNING_SECRET=

# App
ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=development
