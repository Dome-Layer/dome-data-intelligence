NEXT_PUBLIC_API_BASE=http://localhost:8000
# Shared API key matching the backend API_KEY env var. Leave empty for local dev.
NEXT_PUBLIC_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=

# Sentry — client-side error tracking (optional in dev, recommended in production).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
